{
  "editor.formatOnSave": false,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  "[vue]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[javascript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "eslint.validate": ["vue", "typescript", "javascript"],
  "eslint.workingDirectories": [{ "mode": "auto" }],
  "i18n-ally.localesPaths": ["src/locales"],
  "i18n-ally.keystyle": "nested",
  "i18n-ally.sourceLanguage": "es",
  "i18n-ally.displayLanguage": "es",
  "i18n-ally.enabledParsers": ["ts"],
  "i18n-ally.extract.path": "src/locales/{locale}.ts",
  "typescript.tsserver.experimental.enableProjectDiagnostics": true,
  "typescript.preferences.includePackageJsonAutoImports": "on",
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "commandOnAllFiles.commands": {
    "Remove All Comments": {
      "command": "remove-comments.removeAllComments",
      "includeFileExtensions": [".vue", ".ts", ".js", ".css", ".html"],
      "excludeFolders": ["node_modules", "dist"]
    }
  }
}